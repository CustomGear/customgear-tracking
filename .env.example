# CustomGear Google Sheet mapping
# The sheet should have:
# A: Name, B: Destination, C: UPS tracking, D: Client Number (e.g. CG2001)
CUSTOMGEAR_GOOGLE_SHEET_ID=1Q5oH_842W7mfBrcm30APhbQXvpEaO5n0vIK68MVtoF0
CUSTOMGEAR_GOOGLE_SHEET_NAME=Sheet1
# Optional: Google Sheet tab GID (only needed if you have multiple tabs or it fails to resolve)
# CUSTOMGEAR_GOOGLE_SHEET_GID=0
# Optional: if you already have a CSV export link
# CUSTOMGEAR_GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<ID>/gviz/tq?tqx=out:csv&sheet=Sheet1

# UPS integration
# Option A (may or may not work without credentials):
# UPS_GETSTATUS_URL=https://www.ups.com/track/api/Track/GetStatus
UPS_LOCALE=en_US

# Option B (credential-based JSON endpoint):
UPS_USERNAME=your_ups_username
UPS_PASSWORD=your_ups_password
UPS_ACCESS_LICENSE_NUMBER=your_access_license_number

# Optional: your own Apps Script endpoint that returns live UPS status
# Expected shape (flexible):
# { found: true, clientName/destination, upsData: { status, eta, message } }
# CUSTOMGEAR_APPS_SCRIPT_URL=https://script.google.com/macros/s/<id>/exec

# Optional override for the JSON tracking endpoint:
# UPS_TRACK_JSON_URL=https://onlinetools.ups.com/json/Track

